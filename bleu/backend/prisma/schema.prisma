generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id            Int       @id @default(autoincrement())
  title         String
  category      String    @default("Actualité")
  author        String    @default("CSTB Bénin")
  excerpt       String?
  content       String    // Contenu HTML riche
  image         String?   // Base64 ou URL de l'image de couverture
  formattedDate String?   // Date d'affichage manuel (ex: "4 avril 2026")
  likes         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  comments      Comment[]
}

model Comment {
  id         Int      @id @default(autoincrement())
  author     String
  text       String
  date       String
  adminReply String?
  article    Article  @relation(fields: [articleId], references: [id])
  articleId  Int
  createdAt  DateTime @default(now())
}

model Slide {
  id            Int      @id @default(autoincrement())
  title         String   // Sur-titre
  subtitle      String   // Titre principal
  description   String   // Paragraphe texte
  image         String   // Base64 ou URL externe
  primaryBtn    String
  primaryLink   String
  secondaryBtn  String
  secondaryLink String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

model Action {
  id          Int      @id @default(autoincrement())
  title       String
  date        String   // Ex: "Mai 2025"
  description String
  image       String
  articleId   Int?     // ID de l'article lié
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}
model Setting {
  id    String @id
  value String // Stocké en JSON stringifié pour plus de flexibilité
}
